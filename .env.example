# Local development environment variables for Grease Trappers API.
# Copy this to `.env` and fill in real values for local dev.

# REQUIRED in production. Auto-generated by Render via render.yaml.
# Set this to a long random string in production.
JWT_SECRET=local-dev-secret-change-in-prod

# Leave blank locally to enable DEMO_MODE (no DB required, all endpoints return empty/seed).
# Set to a real Postgres URL to connect to a database.
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Optional: server port (Render sets this automatically)
# PORT=5000